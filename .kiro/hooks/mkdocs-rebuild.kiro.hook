{
  "name": "MkDocs Auto Rebuild",
  "description": "When a markdown file in mkdocs/docs/ is saved, automatically runs sync_mkdocs.py to update mkdocs.yml navigation, rebuild the site, and restart mkdocs serve.",
  "version": "1.0.0",
  "when": {
    "type": "fileEdited",
    "patterns": ["mkdocs/docs/**/*.md"]
  },
  "then": {
    "type": "runCommand",
    "command": "python mkdocs/scripts/sync_mkdocs.py"
  }
}
